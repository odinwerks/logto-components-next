# ─────────────────────────────────────────────────────────────────────────────
# Core Logto Configuration (required)
# ─────────────────────────────────────────────────────────────────────────────

# Your Logto application ID
APP_ID=your-app-id

# Your Logto application secret
APP_SECRET=your-app-secret

# Your Logto endpoint (e.g., https://auth.yourdomain.org)
ENDPOINT=https://auth.yourdomain.org

# Your application's base URL for local development (npm run dev)
BASE_URL=http://localhost:3000

# Alternative fallback for BASE_URL (primarily used for origin-guard validation)
# APP_URL=http://localhost:3000

# Public-facing URL for Docker + Cloudflare Tunnel deployment.
# Set this to your CF tunnel URL - docker-compose uses this instead of BASE_URL.
PUBLIC_BASE_URL=https://dash.yourdomain.org

# Cookie secret for session encryption (generate a random string, 32+ chars)
COOKIE_SECRET=your-random-cookie-secret

# Scopes (comma-separated, required - no defaults)
# Must include: openid,profile,custom_data,email,phone,identities,sessions
# Add: organizations for org features
# Add: organization_roles for org role data
# Add: offline_access for refresh tokens
# Custom scopes (e.g. calc:basic) pass through to the Logto SDK unchanged
SCOPES=openid,profile,custom_data,email,phone,identities,sessions,organizations,organization_roles

# Backend type: "blacktop" (custom fork) or "upstream" (stock Logto OSS or Cloud)
# When "blacktop": Enables session heartbeats, lastActiveAt tracking, and Logto Native PFP uploads.
# When "upstream" (default): Disables session heartbeats, hides lastActiveAt, and forces PFP_BACKEND=s3 (disabling Logto Native uploads).
BACKEND_TYPE=upstream

# ─────────────────────────────────────────────────────────────────────────────
# Appearance
# ─────────────────────────────────────────────────────────────────────────────

# Theme folder name (default: default)
THEME=Default
NEXT_PUBLIC_THEME=Default

# Default theme mode before user preferences are loaded (dark | light)
DEFAULT_THEME_MODE=dark
NEXT_PUBLIC_DEFAULT_THEME_MODE=dark

# User avatar shape: circle, sq (square), rsq (rounded square),
# or a custom border-radius value (e.g., 0.5rem, 4px)
USER_SHAPE=circle
NEXT_PUBLIC_USER_SHAPE=circle

# ─────────────────────────────────────────────────────────────────────────────
# i18n
# ─────────────────────────────────────────────────────────────────────────────

# Default language (en-US, ka-GE, or uk-UA)
LANG_MAIN=en-US
NEXT_PUBLIC_LANG_MAIN=en-US

# Available languages (comma-separated)
LANG_AVAILABLE=en-US,ka-GE,uk-UA
NEXT_PUBLIC_LANG_AVAILABLE=en-US,ka-GE,uk-UA

# ─────────────────────────────────────────────────────────────────────────────
# Phone Country Code Filtering (mutually exclusive)
# ─────────────────────────────────────────────────────────────────────────────
# When NEITHER is set, the app auto-defaults to an allow list of US (+1) and Georgia (+995) for registration.

# Comma-separated list of country dial codes to ALLOW (e.g., 1,995,380).
# If specified, ONLY these country codes can be registered/used for phone verification.
# COUNTRY_CODE_ALLOW_LIST=1,995,380

# Comma-separated list of country dial codes to BLOCK (e.g., 7,86).
# If specified, phone numbers from these countries are rejected.
# COUNTRY_CODE_BLOCK_LIST=7,86

# Name display mode: given_family (default), username, or full
NAME_TYPE=given_family
NEXT_PUBLIC_NAME_TYPE=given_family

# ─────────────────────────────────────────────────────────────────────────────
# Dashboard Tabs
# ─────────────────────────────────────────────────────────────────────────────

# Which tabs to show and in what order (comma-separated).
# Allowed: profile, preferences, security, sessions, identities, organizations
# Aliases: personal/user → profile | prefs/custom-data/custom → preferences
#          mfa/2fa/totp → security | devices/activity → sessions
#          identity → identities | orgs/org → organizations
LOAD_TABS=profile,preferences,security,sessions,organizations,identities
NEXT_PUBLIC_LOAD_TABS=profile,preferences,security,sessions,organizations,identities

# Redirect delay after account deletion in ms (default: 3000)
DELETE_REDIRECT_DELAY=3000
NEXT_PUBLIC_DELETE_REDIRECT_DELAY=3000

# ─────────────────────────────────────────────────────────────────────────────
# MFA
# ─────────────────────────────────────────────────────────────────────────────

# App name shown in TOTP authenticator apps (e.g., Google Authenticator).
# MUST match NEXT_PUBLIC_MFA_ISSUER exactly - both are needed to prevent hydration mismatch.
# The server reads MFA_ISSUER; the browser reads NEXT_PUBLIC_MFA_ISSUER.
# If they differ, the TOTP URI generated during SSR won't match the client render,
# causing a React hydration warning and a potentially mismatched QR code on first load.
MFA_ISSUER=YourAppName
NEXT_PUBLIC_MFA_ISSUER=YourAppName

# ─────────────────────────────────────────────────────────────────────────────
# M2M Credentials (for Account Deletion & machine-to-machine RBAC)
# Create an M2M application in Logto Console with "User data → Write" permission
# ─────────────────────────────────────────────────────────────────────────────
# LOGTO_M2M_APP_ID=your-m2m-app-id
# LOGTO_M2M_APP_SECRET=your-m2m-app-secret

# Management API resource URI. OSS default: https://default.logto.app/api
# For Logto Cloud, set to: https://[tenant-id].logto.app/api
# LOGTO_M2M_RESOURCE=https://default.logto.app/api

# Token Introspection (required for Protected Actions API)
# LOGTO_INTROSPECTION_URL=https://auth.yourdomain.org/oidc/token/introspection

# ─────────────────────────────────────────────────────────────────────────────
# Avatar Storage
# ─────────────────────────────────────────────────────────────────────────────

# Avatar backend: "s3" (your own S3-compatible storage) or "logto" (Logto's built-in avatar API).
# When "logto", the Logto endpoint handles upload, storage, cleanup, and profile update
# - no S3 env vars (S3_*, SUPABASE_*) are needed. Defaults to "s3" for backward compatibility.
# PFP_BACKEND=s3

# S3_BUCKET_NAME=avatars
# S3_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/avatars
# S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_REGION=auto

# Supabase service role key (preferred over S3 credentials for Supabase Storage)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─────────────────────────────────────────────────────────────────────────────
# Debug
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to enable verbose server-side debug logging.
# Logs include token introspection details, API request flow, permission checks.
# Default: undefined (no debug logging). Only effective in development.
# DEBUG=true


# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────

# Log backend: console (default), pino (structured JSON), or both
# LOG_BACKEND=console

# Minimum log level: debug, info (default), warn, error
# LOG_LEVEL=info

# Slack or Discord webhook target for error log telemetry
# LOGGING_WEBHOOK_URL=your-logging-webhook-url

# ─────────────────────────────────────────────────────────────────────────────
# Set to "development" to see full RSC errors (Next.js masks them in production).
# Set to "production" for live deployments where error details should be hidden.
# Default: development (safe for beta/dev deployments behind CF Tunnel)
NODE_ENV=development
# ─────────────────────────────────────────────────────────────────────────────
# Before running `docker compose build`:
#   1. Set PUBLIC_BASE_URL above to your public CF tunnel URL
#   2. Fill in CLOUDFLARE_TUNNEL_TOKEN below
#   3. In the Cloudflare dashboard, configure tunnel routing:
#        Public hostname  →  http://logto-dash:2999
#
# To create a tunnel token:
#   https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create a tunnel

CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
