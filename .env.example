# ─────────────────────────────────────────────────────────────────────────────
# Core Logto Configuration (required)
# ─────────────────────────────────────────────────────────────────────────────

# Your Logto application ID
APP_ID=your-app-id

# Your Logto application secret
APP_SECRET=your-app-secret

# Your Logto endpoint (e.g., https://auth.yourdomain.org)
ENDPOINT=https://auth.yourdomain.org

# Your application's base URL for local development (npm run dev)
BASE_URL=http://localhost:3000

# Public-facing URL for Docker + Cloudflare Tunnel deployment.
# Set this to your CF tunnel URL — docker-compose uses this instead of BASE_URL.
PUBLIC_BASE_URL=https://dash.yourdomain.org

# Cookie secret for session encryption (generate a random string, 32+ chars)
COOKIE_SECRET=your-random-cookie-secret

# Scopes (comma-separated, required — no defaults)
# Must include: openid,profile,custom_data,email,phone,identities,sessions
# Add: organizations for org features
# Add: offline_access for refresh tokens
SCOPES=openid,profile,custom_data,email,phone,identities,sessions,organizations

# ─────────────────────────────────────────────────────────────────────────────
# Appearance
# ─────────────────────────────────────────────────────────────────────────────

# Theme folder name (default: Default)
THEME=Default
NEXT_PUBLIC_THEME=Default

# Default theme mode before user preferences are loaded (dark | light)
DEFAULT_THEME_MODE=dark
NEXT_PUBLIC_DEFAULT_THEME_MODE=dark

# User avatar shape: circle, sq (square), rsq (rounded square),
# or a custom border-radius value (e.g., 0.5rem, 4px)
USER_SHAPE=circle
NEXT_PUBLIC_USER_SHAPE=circle

# ─────────────────────────────────────────────────────────────────────────────
# i18n
# ─────────────────────────────────────────────────────────────────────────────

# Default language (en-US or ka-GE)
LANG_MAIN=en-US
NEXT_PUBLIC_LANG_MAIN=en-US

# Available languages (comma-separated)
LANG_AVAILABLE=en-US,ka-GE
NEXT_PUBLIC_LANG_AVAILABLE=en-US,ka-GE

# Name display mode: given_family (default), username, or full
NAME_TYPE=given_family
NEXT_PUBLIC_NAME_TYPE=given_family

# ─────────────────────────────────────────────────────────────────────────────
# Dashboard Tabs
# ─────────────────────────────────────────────────────────────────────────────

# Which tabs to show and in what order (comma-separated).
# Allowed: profile, preferences, security, sessions, identities, organizations, dev
# Aliases: personal/user → profile | prefs/custom-data/custom → preferences
#          mfa/2fa/totp → security | devices/activity → sessions
#          identity → identities | orgs/org → organizations | debug/data/raw → dev
LOAD_TABS=profile,preferences,security,organizations,identities,dev
NEXT_PUBLIC_LOAD_TABS=profile,preferences,security,organizations,identities,dev

# ─────────────────────────────────────────────────────────────────────────────
# MFA
# ─────────────────────────────────────────────────────────────────────────────

# Name shown in the TOTP authenticator QR code
MFA_ISSUER=YourAppName
NEXT_PUBLIC_MFA_ISSUER=YourAppName

# ─────────────────────────────────────────────────────────────────────────────
# M2M Credentials (for Account Deletion & machine-to-machine RBAC)
# Create an M2M application in Logto Console with "User data → Write" permission
# ─────────────────────────────────────────────────────────────────────────────
# LOGTO_M2M_APP_ID=your-m2m-app-id
# LOGTO_M2M_APP_SECRET=your-m2m-app-secret
# LOGTO_M2M_RESOURCE=https://your-tenant.logto.app/api

# Token Introspection (required for Protected Actions API)
# LOGTO_INTROSPECTION_URL=https://auth.yourdomain.org/oidc/token/introspection

# ─────────────────────────────────────────────────────────────────────────────
# Avatar Storage (S3-compatible — Supabase Storage works out of the box)
# ─────────────────────────────────────────────────────────────────────────────
# S3_BUCKET_NAME=avatars
# S3_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/avatars
# S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_REGION=auto

# Supabase service role key (preferred over S3 credentials for Supabase Storage)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─────────────────────────────────────────────────────────────────────────────
# Demo App
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable the Canvas 2D particle animation in the demo sidebar.
# Set to false on mobile or low-power deployments to avoid CPU/GPU hammering.
NEXT_PUBLIC_DEMO_PARTICLES=true

# ─────────────────────────────────────────────────────────────────────────────
# Debug
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to enable verbose server-side debug logging (dev only)
# DEBUG=true

# ─────────────────────────────────────────────────────────────────────────────
# Docker / Cloudflare Tunnel Deployment
# ─────────────────────────────────────────────────────────────────────────────
# Before running `docker compose build`:
#   1. Set BASE_URL above to your public CF tunnel URL (e.g. https://dash.yourdomain.org)
#   2. Fill in CLOUDFLARE_TUNNEL_TOKEN below
#   3. In the Cloudflare dashboard, configure tunnel routing:
#        Public hostname  →  http://logto-dash:3000
#
# To create a tunnel token:
#   https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create a tunnel

CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
