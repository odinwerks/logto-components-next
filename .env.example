# Your Logto application ID
APP_ID=your-app-id

# Your Logto application secret
APP_SECRET=your-app-secret

# Your Logto endpoint (e.g., https://auth.yourdomain.org)
ENDPOINT=https://auth.yourdomain.org

# Your application's base URL
BASE_URL=http://localhost:3000

# Cookie secret for session encryption (generate a random string)
COOKIE_SECRET=your-random-cookie-secret

# Scopes (comma-separated, required - no defaults)
# Must include: openid,profile,custom_data,email,phone,identities,sessions
# Add: organizations for org features
# Add: organization permissions (kidnap:kids, steal:taxes) for org token scopes
# Add: offline_access for refresh tokens
SCOPES=openid,profile,custom_data,email,phone,identities,sessions,organizations,kidnap:kids,steal:taxes

# Theme Configuration
# Theme folder name (default: default)
THEME=default

# Default theme mode before user preferences are read from Logto (dark | light)
DEFAULT_THEME_MODE=dark

# User avatar shape: circle, sq (square), rsq (rounded square), or custom border-radius (e.g., 0.5rem, 4px)
USER_SHAPE=circle

# i18n Configuration
# Default language (en-US or ka-GE)
LANG_MAIN=en-US

# Available languages (comma-separated)
LANG_AVAILABLE=en-US,ka-GE

# Tab Configuration
# Which tabs to show and in what order (comma-separated)
# Allowed: profile, preferences, security, sessions, identities, organizations, dev
# Aliases: personal, user → profile; prefs, custom-data, custom, customdata → preferences; mfa, 2fa, totp → security; sessions, session, devices, activity → sessions; identity → identities; orgs, org → organizations; debug, data, raw → dev
LOAD_TABS=profile,preferences,security,organizations,identities,dev

# MFA Configuration
# Name that will show up in the TOTP QR
MFA_ISSUER=YourAppName

# Note: User preferences (theme and language) are automatically stored in Logto customData under the "Preferences" key.
# Update your Logto application's JSON schema to include this key for type safety.

# M2M Credentials (for Account Deletion & RBAC)
# Create an M2M application in Logto Console with "User data" > "Write" permission
# LOGTO_M2M_APP_ID=your-m2m-app-id
# LOGTO_M2M_APP_SECRET=your-m2m-app-secret
# LOGTO_M2M_RESOURCE=https://your-tenant.logto.app/api

# Token Introspection (required for Protected Actions API)
# LOGTO_INTROSPECTION_URL=https://your-tenant.logto.app/oidc/token/introspection

# S3 Storage (for Avatar Upload)
# S3_BUCKET_NAME=avatars
# S3_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/avatars
# S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_REGION=auto

# Optional: Supabase REST API (more reliable than S3 compatibility)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Session Metadata Storage (uses same S3/Supabase config as avatar upload)
# Bucket for storing per-session device/UX metadata.
# If not set, falls back to S3_BUCKET_NAME.
# S3_SESSION_BUCKET=session-meta

# =============================================================================
# Heartbeat Configuration (Session Security)
# =============================================================================

# Storage mode: 'memory' (dev, no Redis needed) or 'redis' (prod, requires Redis)
HEARTBEAT_MODE=memory

# Memory mode settings (only used when HEARTBEAT_MODE=memory)
HEARTBEAT_CLEANUP_INTERVAL_MS=60000    # How often to cleanup expired entries (default: 60s)
HEARTBEAT_MAX_AGE_MS=60000             # Max age before entry is considered expired (default: 60s)

# Redis mode settings (only used when HEARTBEAT_MODE=redis)
# REDIS_HOST=localhost                   # Redis server hostname
# REDIS_PORT=6379                        # Redis server port
# REDIS_PASSWORD=                        # Redis password (optional)
# REDIS_DB=0                             # Redis database number
# REDIS_HEARTBEAT_PREFIX=hb:             # Key prefix for heartbeat entries
# REDIS_HEARTBEAT_TTL=60                 # TTL in seconds (should match HEARTBEAT_MAX_AGE_MS)

# =============================================================================
# Webhook Configuration (for session metadata webhook)
# =============================================================================

# Webhook signing key — get from Logto Console > Webhooks > your webhook > Signing key
# LOGTO_WEBHOOK_SIGNING_KEY=your_signing_key
