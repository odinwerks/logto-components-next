# Optional: For RBAC (Role-Based Access Control)
# RESOURCES=your_resource1,your_resource2
SCOPES=openid,profile,custom_data,email,phone,identities,sessions,organizations,organization_roles,calc:basic,calc:scientific

# Set theme
THEME=Default
NEXT_PUBLIC_THEME=Default

# Default language (en-US or ka-GE)
LANG_MAIN=en-US
NEXT_PUBLIC_LANG_MAIN=en-US

# Available languages (comma-separated)
LANG_AVAILABLE=en-US,ka-GE
NEXT_PUBLIC_LANG_AVAILABLE=en-US,ka-GE

# Name that will show up in the TOTP QR.
MFA_ISSUER=Nebakoploba
NEXT_PUBLIC_MFA_ISSUER=Nebakoploba

# Default theme mode before user preferences are read from Logto (dark | light)
DEFAULT_THEME_MODE=dark
NEXT_PUBLIC_DEFAULT_THEME_MODE=dark

# User avatar shape: circle, sq (square), rsq (rounded square), or custom border-radius (e.g., 0.5rem)
USER_SHAPE=sq
NEXT_PUBLIC_USER_SHAPE=sq

# Name display mode: given_family (default), username, or full
NAME_TYPE=given_family
NEXT_PUBLIC_NAME_TYPE=given_family

# Which tabs to show and in what order (comma-separated) (besids those added, there is a sessions tab which is not active by default since the code for that is NOT finished and will take a lot more work to make usable.)
LOAD_TABS=profile,custom-data,mfa,organizations,sessions,identities,raw
NEXT_PUBLIC_LOAD_TABS=profile,custom-data,mfa,organizations,sessions,identities,raw

